{
  "name": "pruner-proxy",
  "version": "1.0.0",
  "description": "Fastify-based HTTP proxy for Anthropic API optimization",
  "main": "dist/proxy.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/proxy.ts",
    "dev:test": "tsx src/test-proxy.ts",
    "start": "node dist/proxy.js",
    "test": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": ["proxy", "fastify", "anthropic"],
  "author": "Pruner Team",
  "license": "MIT",
  "dependencies": {
    "fastify": "^4.26.0",
    "@fastify/http-proxy": "^9.5.0",
    "undici": "^6.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "vitest": "^1.2.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "prettier": "^3.2.5"
  }
}